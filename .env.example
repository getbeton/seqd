# Database
DATABASE_URL=postgresql://seqd:seqd@localhost:5432/seqd

# Redis
REDIS_URL=redis://localhost:6379

# Google OAuth (GCP project, OAuth2 Web Application client)
# Used for both Gmail mailbox OAuth AND Google sign-in
# Redirect URIs in GCP console must include:
#   http://localhost:3000/api/mailboxes/auth/callback
#   http://localhost:3000/api/auth/callback/google
#   https://your-domain.vercel.app/api/mailboxes/auth/callback
#   https://your-domain.vercel.app/api/auth/callback/google
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/mailboxes/auth/callback

# Token Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
TOKEN_ENCRYPTION_KEY=

# Auth (BetterAuth)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Cron endpoint protection
CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
