# Database
DATABASE_URL=postgresql://seqd:seqd@localhost:5432/seqd

# Redis
REDIS_URL=redis://localhost:6379

# Gmail OAuth (GCP project: getbeton-ai, OAuth2 Desktop App client)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/mailboxes/auth/callback

# Token Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
TOKEN_ENCRYPTION_KEY=

# Auth (BetterAuth)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Cron endpoint protection
CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
